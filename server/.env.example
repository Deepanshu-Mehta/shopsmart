NODE_ENV=development
PORT=5001
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vestir_db?schema=public"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
